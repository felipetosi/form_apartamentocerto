function copiarTexto() {
  const linhas = [];
  linhas.push('FORMULÁRIO DE ONBOARDING — GESTÃO DE MÍDIA LAVVI');
  linhas.push('='.repeat(50));

  const rows = document.querySelectorAll('.summary-row');
  rows.forEach(r => {
    const label = r.querySelector('.summary-label')?.textContent || '';
    const value = r.querySelector('.summary-value')?.textContent || '';
    linhas.push(`${label}: ${value}`);
  });

  navigator.clipboard.writeText(linhas.join('\n')).then(() => {
    alert('Resumo copiado para a área de transferência!');
  });
}

function updateSlider(sliderId, valId, prefix, suffix) {
  const val = parseInt(document.getElementById(sliderId).value);
  document.getElementById(valId).textContent = prefix + val.toLocaleString('pt-BR') + suffix;
}

