<script>
let currentSection = 1;
const totalSections = 6;

function buildStepIndicator() {
  const el = document.getElementById('stepIndicator');
  el.innerHTML = '';
  for (let i = 1; i <= totalSections; i++) {
    const dot = document.createElement('div');
    dot.className = 'step-dot' + (i === currentSection ? ' active' : (i < currentSection ? ' done' : ''));
    el.appendChild(dot);
  }
}

function updateProgress() {
  const pct = ((currentSection - 1) / (totalSections - 1)) * 100;
  document.getElementById('progressBar').style.width = pct + '%';
}

function navegarSecao(dir) {
  if (dir === 1 && currentSection === totalSections - 1) {
    gerarResumo();
  }

  document.getElementById('section-' + currentSection).classList.remove('active');
  currentSection += dir;
  if (currentSection < 1) currentSection = 1;
  if (currentSection > totalSections) currentSection = totalSections;
  document.getElementById('section-' + currentSection).classList.add('active');

  document.getElementById('btnVoltar').style.display = currentSection > 1 ? 'block' : 'none';
  document.getElementById('btnAvancar').textContent = currentSection === totalSections ? '✓ Concluído' : (currentSection === totalSections - 1 ? 'Ver Resumo →' : 'Avançar →');
  if (currentSection === totalSections) {
    document.getElementById('btnAvancar').style.display = 'none';
  } else {
    document.getElementById('btnAvancar').style.display = 'block';
  }

  buildStepIndicator();
  updateProgress();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function val(id) {
  const el = document.getElementById(id);
  return el ? (el.value || '—') : '—';
}

function radioVal(name) {
  const el = document.querySelector(`input[name="${name}"]:checked`);
  return el ? el.parentElement.querySelector('span').textContent : '—';
}

function checkVals(name) {
  const els = document.querySelectorAll(`input[name="${name}"]:checked`);
  if (!els.length) return '—';
  return Array.from(els).map(e => e.parentElement.querySelector('span').textContent).join(', ');
}

