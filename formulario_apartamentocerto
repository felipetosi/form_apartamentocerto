  rb.addEventListener('change', () => {
    document.querySelectorAll(`input[name="${rb.name}"]`).forEach(r => {
      r.parentElement.classList.remove('checked');
    });
    rb.parentElement.classList.add('checked');
  });
});

// Init
buildStepIndicator();
updateProgress();
</script>

